# ----- Required -----

# Address of the ERC-20 token users will deposit into the vault.
STAKE_TOKEN=0x0000000000000000000000000000000000000000

# Initial vault owner (Ownable2Step). Usually your treasury or multisig.
# This address can adjust cooldown params and rescue accidentally-sent non-stake tokens.
# It CANNOT rescue the stake token, mint, burn, pause, or upgrade.
OWNER=0x0000000000000000000000000000000000000000

# Share-token display metadata.
VAULT_NAME=Staked YOURTOKEN
VAULT_SYMBOL=xYOURTOKEN

# Deployer key. The deployer doesn't need to equal OWNER.
PRIVATE_KEY=0x...

# RPC + verification.
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=your_basescan_key

# ----- Optional -----

# Cooldown duration in seconds. Default 3 days (259200). Max 30 days.
# COOLDOWN_PERIOD=259200

# Withdraw window in seconds. Default 2 days (172800). Min 1 day.
# WITHDRAW_WINDOW=172800

# For other chains:
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# MAINNET_RPC_URL=https://eth.llamarpc.com
# ETHERSCAN_API_KEY=your_etherscan_key
