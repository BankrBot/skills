{
  "name": "mythosforge-imageedit",
  "version": "1.0.0",
  "description": "Edit an image with a prompt (instruction img2img) or inpaint a masked region, via Replicate.",
  "type": "module",
  "bin": { "mythosforge-imageedit": "imageedit.mjs" },
  "scripts": {
    "test": "node selftest.mjs",
    "dry-run": "node imageedit.mjs --op edit --image ./example.png --prompt \"make it snowy\" --dry-run"
  },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "keywords": ["ai", "agent", "skill", "image-edit", "inpaint", "img2img", "replicate", "byo-key", "mythosforge"],
  "files": ["imageedit.mjs", "selftest.mjs", "SKILL.md", "AGENTS.md", "skill.json", "tool-schema.json", "references/", "README.md", "LICENSE"]
}
